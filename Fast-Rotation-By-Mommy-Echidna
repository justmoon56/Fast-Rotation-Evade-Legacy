--// EVADE DOWNED / EMOTE STRAFE ROTATION (SMOOTH + NO SHAKE)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local connection

-- SETTINGS
local TURN_SPEED = 45         -- smoothness (higher = faster turn)
local STRAFE_POWER = 95       -- how strong left/right rotation is
local THRESHOLD = 0.03        -- joystick sensitivity

local function setup(char)
    if connection then
        connection:Disconnect()
    end

    local humanoid = char:WaitForChild("Humanoid")
    local root = char:WaitForChild("HumanoidRootPart")

    -- CLEAN OLD ALIGNS
    for _, v in pairs(root:GetChildren()) do
        if v:IsA("AlignOrientation") then
            v:Destroy()
        end
    end

    -- ATTACHMENT
    local att = Instance.new("Attachment")
    att.Name = "RootAttachment"
    att.Parent = root

    -- Align (For no Bugs)
local align = Instance.new("AlignOrientation")
align.Attachment0 = att
align.Mode = Enum.OrientationAlignmentMode.OneAttachment
align.Responsiveness = 120 -- lower = less aggressive (important)
align.RigidityEnabled = false
align.MaxTorque = 50000 -- 🔥 not infinite (fixes sticking)
align.Parent = root

    connection = RunService.RenderStepped:Connect(function(dt)
        if not root or not root.Parent then return end

        local move = humanoid.MoveDirection
        local isDowned = humanoid.Health <= 0 or humanoid:GetState() == Enum.HumanoidStateType.Dead

        -- detect if emoting (animation playing)
        local isEmoting = #humanoid:GetPlayingAnimationTracks() > 0

        -- ONLY WORK WHEN DOWNED OR EMOTING
        if not (isDowned or isEmoting) then return end

        if move.Magnitude > THRESHOLD then
            -- BASE LOOK DIRECTION
            local look = CFrame.lookAt(root.Position, root.Position + root.CFrame.LookVector)

            -- STRAFE DETECTION (LEFT / RIGHT)
            local strafe = move:Dot(root.CFrame.RightVector)

            if math.abs(strafe) > THRESHOLD then
                -- APPLY LEFT / RIGHT ROTATION
                local angle = math.rad(-strafe * STRAFE_POWER)
                look = look * CFrame.Angles(0, angle, 0)
            end

            -- SMOOTH APPLY (NO SNAP)
            align.CFrame = align.CFrame:Lerp(look, dt * TURN_SPEED)
        end
    end)

    -- RESET ON DEATH
    humanoid.Died:Connect(function()
        if connection then
            connection:Disconnect()
        end
    end)
end

-- INIT
if player.Character then
    setup(player.Character)
end

player.CharacterAdded:Connect(setup)
